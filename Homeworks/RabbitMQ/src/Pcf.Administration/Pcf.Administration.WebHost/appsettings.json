{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "ConnectionStrings": {
    "PromocodeFactoryAdministrationDb": "Host=localhost;Database=promocode_factory_administration_db;Username=postgres;Password=docker;Port=5433"
  },
  "MessageBus": {
    "RabbitMq": {
      "Connection": {
        "HostName": "localhost",
        "Port": 5672,
        "UserName": "admin",
        "Password": "docker",
        "VirtualHost": "/",
        "ClientProvidedName": "administration-api:consumer",
        "AutomaticRecoveryEnabled": true,
        "TopologyRecoveryEnabled": true,
        "ConsumerDispatchConcurrency": 1
      },
      "Publish": {},
      "Subscriptions": {
        "partner-manager-received": {
          "Exchange": "receive-promocode.events",
          "ExchangeType": "topic",
          "Queue": "partner-manager-received",
          "RoutingKey": "partner-manager.received",
          "Durable": true,
          "Exclusive": false,
          "AutoDelete": false,
          "PrefetchCount": 10,
          "EnableDeadLetter": true,
          "DeadLetterExchange": "partner-manager-received.dlx",
          "DeadLetterQueue": "partner-manager-received.dlq",
          "DeadLetterRoutingKey": "partner-manager-received.dlq",
          "EnableRetry": true,
          "RetryExchange": "partner-manager-received.retry.exchange",
          "RetryQueue": "partner-manager-received.retry",
          "RetryRoutingKey": "partner-manager-received.retry",
          "RetryTtlMilliseconds": 30000,
          "MaxRetryCount": 3
        }
      }
    }
  },
  "AllowedHosts": "*"
}
